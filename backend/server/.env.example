# MongoDB Atlas Connection String - REPLACE WITH YOUR ACTUAL CREDENTIALS
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
# MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/typevex?retryWrites=true&w=majority

# MongoDB Local Connection String (for local development)
MONGO_URI=mongodb://localhost:27017/mokey_type_db

# Server Port (Render default is 10000)
PORT=10000

# Environment
NODE_ENV=production

# JWT Secret - CHANGE THIS TO A LONG RANDOM STRING IN PRODUCTION
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_at_least_32_characters_long