
MONGO_URI=mongodb://localhost:27017/mokey_type_db

# PostgreSQL local connection string (replace 'your_password' with your PGAdmin postgres user password!)
POSTGRES_URI=postgres://postgres:0418@localhost:5432/typevex

# Server Port
PORT=10000

# Environment
NODE_ENV=development

# JWT Secret - CHANGE THIS TO A LONG RANDOM STRING IN PRODUCTION
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_at_least_32_characters_long
# Frontend URL (for OAuth redirects)
CLIENT_URL=http://localhost:5173

# Cookie Options
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax
